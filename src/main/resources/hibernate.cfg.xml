<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/xettuyen2026?useSSL=false&amp;serverTimezone=UTC&amp;useUnicode=true&amp;characterEncoding=UTF-8</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password"></property>
        <property name="hibernate.dialect">org.hibernate.dialect.MySQL8Dialect</property>
        
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <property name="hibernate.globally_quoted_identifiers">true</property>
        
        <property name="hibernate.hbm2ddl.auto">update</property>
        
        <!-- Entity Mappings -->
        <mapping class="vn.edu.sgu.phanmemtuyensinh.dal.entity.NguoiDung"/>
        <mapping class="vn.edu.sgu.phanmemtuyensinh.dal.entity.ThiSinh"/>
        <mapping class="vn.edu.sgu.phanmemtuyensinh.dal.entity.Nganh"/>
        <mapping class="vn.edu.sgu.phanmemtuyensinh.dal.entity.NganhToHop"/>
        <mapping class="vn.edu.sgu.phanmemtuyensinh.dal.entity.DiemThiXetTuyen"/>
        <mapping class="vn.edu.sgu.phanmemtuyensinh.dal.entity.DiemCongXetTuyen"/>
        <mapping class="vn.edu.sgu.phanmemtuyensinh.dal.entity.NguyenVongXetTuyen"/>
        <mapping class="vn.edu.sgu.phanmemtuyensinh.dal.entity.BangQuyDoi"/>
        <mapping class="vn.edu.sgu.phanmemtuyensinh.dal.entity.ToHopMon"/>

        </session-factory>
</hibernate-configuration>